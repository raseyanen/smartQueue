#!/bin/bash
# Homebrew-обёртка для SmartQueue

SMARTQUEUE_DIR="$HOME/.smartqueue"
# ПРАВИЛЬНЫЙ ПУТЬ К ФАЙЛАМ В CELLAR
HOMEBREW_CELLAR="/opt/homebrew/Cellar/smartqueue/1.0.1"

case "$1" in
  start)
    echo "🚀 Starting SmartQueue..."
    mkdir -p "$SMARTQUEUE_DIR"
    
    # Копируем и ПЕРЕИМЕНОВЫВАЕМ в docker-compose.yml
    if [ ! -f "$SMARTQUEUE_DIR/docker-compose.yml" ]; then
        if [ -f "$HOMEBREW_CELLAR/docker-compose.prod.yml" ]; then
            cp "$HOMEBREW_CELLAR/docker-compose.prod.yml" "$SMARTQUEUE_DIR/docker-compose.yml"
            echo "✓ Copied docker-compose.yml"
        else
            echo "❌ Error: docker-compose.prod.yml not found in $HOMEBREW_CELLAR"
            exit 1
        fi
    fi
    
    if [ ! -f "$SMARTQUEUE_DIR/.env" ]; then
        if [ -f "$HOMEBREW_CELLAR/.env.example" ]; then
            cp "$HOMEBREW_CELLAR/.env.example" "$SMARTQUEUE_DIR/.env"
            echo "✓ Created .env file"
            echo "⚠️  Please edit $SMARTQUEUE_DIR/.env and set your passwords"
            echo "   Then run 'smartqueue start' again"
            exit 1
        else
            echo "❌ Error: .env.example not found in $HOMEBREW_CELLAR"
            exit 1
        fi
    fi
    
    cd "$SMARTQUEUE_DIR"
    docker-compose up -d
    echo "✅ SmartQueue started at http://localhost:8000"
    ;;
    
  stop)
    cd "$SMARTQUEUE_DIR" 2>/dev/null && docker-compose down 2>/dev/null
    echo "✅ Stopped"
    ;;
    
  logs)
    cd "$SMARTQUEUE_DIR" 2>/dev/null && docker-compose logs -f || echo "❌ Not initialized. Run 'smartqueue start' first."
    ;;
    
  restart)
    $0 stop && $0 start
    ;;
    
  status)
    cd "$SMARTQUEUE_DIR" 2>/dev/null && docker-compose ps 2>/dev/null || echo "⚠️  Not running or not initialized"
    ;;
    
  *)
    echo "Usage: smartqueue {start|stop|restart|logs|status}"
    echo ""
    echo "Commands:"
    echo "  start    - Start all services"
    echo "  stop     - Stop all services"
    echo "  restart  - Restart all services"
    echo "  logs     - View logs"
    echo "  status   - Show container status"
    ;;
esac
